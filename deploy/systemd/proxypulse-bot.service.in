[Unit]
Description=ProxyPulse Telegram Bot
After=network-online.target proxypulse-api.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=__WORKDIR__
EnvironmentFile=__ENV_FILE__
ExecStart=__PYTHON__ -m proxypulse.bot
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

